DB_NAME=
DB_USER=
DB_PASSWORD=

# Chave secreta utilizada para assinar os tokens JWT.
# Utilize um valor longo e aleatório em formato Base64 (mínimo 32 caracteres).
# Gere com: openssl rand -base64 64
JWT_SECRET=

# Tempo de expiração do access token em milissegundos.
# Exemplo: 900000 = 15 minutos | 1800000 = 30 minutos
JWT_EXPIRATION=

# Tempo de expiração do refresh token em milissegundos.
# Exemplo: 2592000000 = 30 dias | 604800000 = 7 dias
JWT_REFRESH_TOKEN_EXPIRATION=